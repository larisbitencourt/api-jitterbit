{
  "name": "api-jitterbit",
  "version": "1.0.0",
  "description": "API para o teste técnico Jitterbit",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "lint": "eslint .",
    "seed": "node src/seed.js",
    "setup": "npm run seed && npm run dev",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "jest tests/unit",
    "test:integration": "mocha tests/integration/**/*.test.js --exit"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.0",
    "swagger-ui-express": "^5.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "eslint": "^9.0.0",
    "@eslint/js": "^9.0.0",
    "globals": "^15.0.0",
    "jest": "^29.0.0",
    "mocha": "^10.0.0",
    "chai": "^4.3.0",
    "supertest": "^6.3.0",
    "mongodb-memory-server": "^8.0.0"
  }
}