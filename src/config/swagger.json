{
  "openapi": "3.0.0",
  "info": {
    "title": "API Jitterbit - Gestão de Pedidos",
    "version": "1.0.0",
    "description": "Documentação interativa para o desafio técnico. Lógica de estoque e permissões inclusas."
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Servidor Local"
    }
  ],
  "paths": {
    "/user": {
      "post": {
        "tags": ["Usuários"],
        "summary": "Cadastro de novo usuário",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string", "example": "Larissa Administrator" },
                  "email": { "type": "string", "example": "admin@teste.com" },
                  "password": { "type": "string", "example": "123" },
                  "role": { "type": "string", "example": "admin" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Usuário criado com sucesso" },
          "400": { "description": "Erro no cadastro" }
        }
      }
    },
    "/login": {
      "post": {
        "tags": ["Autenticação"],
        "summary": "Login do sistema",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "example": "admin@teste.com" },
                  "password": { "type": "string", "example": "123" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Login realizado com sucesso" },
          "401": { "description": "Usuário ou senha inválidos" },
          "500": { "description": "Erro no servidor" }
        }
      }
    },
    "/order": {
      "post": {
        "tags": ["Pedidos"],
        "summary": "Criar Pedido (Admin)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "numeroPedido": { "type": "string", "example": "JIT-2026" },
                  "valorTotal": { "type": "number", "example": 1500.50 },
                  "dataCriacao": { "type": "number", "example": "2026-03-07T14:00:00Z" },
                  "items": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "idItem": { "type": "string", "example": "1" },
                        "quantidadeItem": { "type": "number", "example": 2 },
                        "valorItem": { "type": "number", "example": 750.25 }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Pedido criado com sucesso" },
          "400": { "description": "Falha ao criar o pedido" },
          "403": { "description": "Acesso negado: Esta operação requer perfil de administrador." }
        }
      }
    },
    "/order/list": {
      "get": {
        "tags": ["Pedidos"],
        "summary": "Listar todos os pedidos",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Pedidos buscados com sucesso" },
          "401": { "description": "Token inválido ou expirado" },
          "500": { "description": "Erro ao buscar pedidos" }
        }
      }
    },
    "/order/{orderId}": {
      "get": {
        "tags": ["Pedidos"],
        "summary": "Buscar pedido por ID",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "orderId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Pedido retornado com sucesso" },
          "401": { "description": "Token inválido" },
          "404": { "description": "Não encontrado, verifique o número do pedido" },
          "500": { "description": "Erro ao buscar pedido" }
        }
      },
      "put": {
        "tags": ["Pedidos"],
        "summary": "Atualizar Pedido (Admin)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "orderId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "valorTotal": { "type": "number", "example": 1800.00 },
                  "items": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "idItem": { "type": "string", "example": "1" },
                        "quantidadeItem": { "type": "number", "example": 3 },
                        "valorItem": { "type": "number", "example": 600.00 }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Pedido atualizado com sucesso" },
          "400": { "description": "Erro ao atualizar pedido" },
          "403": { "description": "Acesso negado: Esta operação requer perfil de administrador." },
          "404": { "description": "Pedido não encontrado para atualização" }
        }
      },
      "delete": {
        "tags": ["Pedidos"],
        "summary": "Remover Pedido (Admin)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "orderId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "204": { "description": "Pedido deletado com sucesso" },
          "403": { "description": "Acesso negado: Esta operação requer perfil de administrador." },
          "404": { "description": "Pedido não encontrado para exclusão" },
          "500": { "description": "Erro ao deletar pedido" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}